# SpaceGuard Backend — copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Firebase Admin SDK JSON file (download from Firebase Console → Project Settings → Service Accounts)
# Place the file inside the backend/ directory.
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Mistral AI — used by the risk-assessment agent (step 4)
# Get a free key at https://console.mistral.ai → API Keys (enable billing for production)
# The pipeline runs without this key — the agent will return IGNORE/failure safely.
MISTRAL_API_KEY=your_mistral_api_key_here

# NASA APIs — used for Near Earth Objects (NeoWs) and Space Weather (DONKI)
# DEMO_KEY is used automatically if this is not set (rate-limited to ~30 req/hr).
# Get a free key at https://api.nasa.gov
NASA_API_KEY=your_nasa_api_key_here

# OpenWeatherMap — used to augment launch risk with pad weather data (optional)
# Get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here
