# SpaceGuard Frontend — optional for local dev
# When hosting the frontend (e.g. Vercel), set this to your backend API URL.
# Leave unset for local dev (defaults to http://localhost:8000).

# NEXT_PUBLIC_API_URL=https://your-backend-api.example.com

# Firebase Web app (required for Risk Monitor + live Firestore listeners).
# Firebase Console -> Project settings -> Your apps -> Web app -> SDK snippet -> copy into .env.local
# Without these, the UI can sit on "Scanning Deep Space..." forever.

# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=spaceguard-a0dbc
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# ElevenLabs TTS — enables the 🔊 speak button in the Risk Assessment panel.
# Get your key at https://elevenlabs.io → Profile → API Keys
# NEXT_PUBLIC_ELEVENLABS_API_KEY=your_key_here
